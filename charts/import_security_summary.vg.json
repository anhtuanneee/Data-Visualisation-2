{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Fuel on the Way Helps, But Cover Often Falls Short",
    "subtitle": "Monthly IEA days of net import cover including stocks on land, on vessels and overseas, 2018 to Feb 2026",
    "anchor": "start",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "subtitleColor": "#6b7280",
    "offset": 12
  },
  "data": {
    "url": "data/fuel_cover_including_onway.csv",
    "format": {
      "type": "csv",
      "parse": {
        "Month": "date",
        "On land stocks (days)": "number",
        "Onboard vessels (days)": "number",
        "Overseas awaiting delivery (days)": "number",
        "Total cover (days)": "number"
      }
    }
  },
  "width": "container",
  "height": 370,
  "layer": [
    {
      "transform": [
        {
          "fold": [
            "On land stocks (days)",
            "Onboard vessels (days)",
            "Overseas awaiting delivery (days)"
          ],
          "as": [
            "Cover component",
            "Days"
          ]
        },
        {
          "calculate": "datum['Cover component'] == 'On land stocks (days)' ? 1 : datum['Cover component'] == 'Onboard vessels (days)' ? 2 : 3",
          "as": "Component order"
        }
      ],
      "mark": {
        "type": "area",
        "opacity": 0.82
      },
      "encoding": {
        "x": {
          "field": "Month",
          "type": "temporal",
          "title": "Month",
          "scale": {
            "domain": [
              "2018-01-01",
              "2026-08-01"
            ]
          },
          "axis": {
            "format": "%Y",
            "labelAngle": 0,
            "grid": false
          }
        },
        "y": {
          "field": "Days",
          "type": "quantitative",
          "title": "Days of net import cover",
          "scale": {
            "domain": [
              0,
              110
            ]
          },
          "axis": {
            "gridColor": "#e5e7eb"
          },
          "stack": "zero"
        },
        "color": {
          "field": "Cover component",
          "type": "nominal",
          "title": null,
          "scale": {
            "domain": [
              "On land stocks (days)",
              "Onboard vessels (days)",
              "Overseas awaiting delivery (days)"
            ],
            "range": [
              "#4f78a8",
              "#e5a936",
              "#59a14f"
            ]
          },
          "legend": {
            "orient": "bottom",
            "labelExpr": "replace(replace(datum.label, ' (days)', ''), 'Onboard vessels', 'Vessels at sea')"
          }
        },
        "order": {
          "field": "Component order",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "Month",
            "type": "temporal",
            "title": "Month",
            "format": "%b %Y"
          },
          {
            "field": "Cover component",
            "type": "nominal",
            "title": "Component"
          },
          {
            "field": "Days",
            "type": "quantitative",
            "title": "Days",
            "format": ".0f"
          },
          {
            "field": "Total cover (days)",
            "type": "quantitative",
            "title": "Total cover",
            "format": ".0f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "line",
        "strokeWidth": 2.8,
        "color": "#111827"
      },
      "encoding": {
        "x": {
          "field": "Month",
          "type": "temporal"
        },
        "y": {
          "field": "Total cover (days)",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "Month",
            "type": "temporal",
            "title": "Month",
            "format": "%b %Y"
          },
          {
            "field": "Total cover (days)",
            "type": "quantitative",
            "title": "Total cover",
            "format": ".0f"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "Benchmark": 90
          }
        ]
      },
      "mark": {
        "type": "rule",
        "strokeDash": [
          6,
          5
        ],
        "strokeWidth": 2,
        "color": "#d5972f"
      },
      "encoding": {
        "y": {
          "field": "Benchmark",
          "type": "quantitative"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "Month": "2026-07-01",
            "Benchmark": 90,
            "Label": "IEA 90-day benchmark"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "right",
        "baseline": "bottom",
        "dy": -6,
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#8a641f"
      },
      "encoding": {
        "x": {
          "field": "Month",
          "type": "temporal"
        },
        "y": {
          "field": "Benchmark",
          "type": "quantitative"
        },
        "text": {
          "field": "Label"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "Month": "2026-02-01",
            "Total cover (days)": 61,
            "Label": "Feb 2026: 61 days including fuel on the way"
          }
        ]
      },
      "mark": {
        "type": "point",
        "filled": true,
        "size": 120,
        "color": "#111827",
        "stroke": "#ffffff",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": {
          "field": "Month",
          "type": "temporal"
        },
        "y": {
          "field": "Total cover (days)",
          "type": "quantitative"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "Month": "2026-02-01",
            "Total cover (days)": 61,
            "Label": "Feb 2026: 61 days including fuel on the way"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 10,
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#374151"
      },
      "encoding": {
        "x": {
          "field": "Month",
          "type": "temporal"
        },
        "y": {
          "field": "Total cover (days)",
          "type": "quantitative"
        },
        "text": {
          "field": "Label"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "Month": "2021-04-01",
            "Total cover (days)": 104,
            "Label": "Peak: 104 days"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "bottom",
        "dx": 8,
        "dy": -4,
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#374151"
      },
      "encoding": {
        "x": {
          "field": "Month",
          "type": "temporal"
        },
        "y": {
          "field": "Total cover (days)",
          "type": "quantitative"
        },
        "text": {
          "field": "Label"
        }
      }
    }
  ],
  "config": {
    "background": "#ffffff",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#374151",
      "titleColor": "#374151"
    },
    "legend": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#374151",
      "titleColor": "#374151"
    },
    "title": {
      "font": "Inter, Arial, sans-serif"
    }
  }
}
