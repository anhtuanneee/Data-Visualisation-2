{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Road Fuel Demand Heat Map by State",
    "subtitle": "Cell labels = billion litres; colour = % change from 2011; dashed gold = 2020 COVID dip year; black border = peak year",
    "anchor": "start",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "subtitleColor": "#6b7280",
    "offset": 12
  },
  "data": {
    "url": "data/state_road_fuel_sales_annual.csv",
    "format": {
      "type": "csv",
      "parse": {
        "State Order": "number",
        "Year": "number",
        "Petrol ML": "number",
        "Diesel ML": "number",
        "Road fuel ML": "number"
      }
    }
  },
  "transform": [
    {
      "calculate": "datum['Road fuel ML'] / 1000",
      "as": "Road fuel BL"
    },
    {
      "calculate": "datum['Petrol ML'] / 1000",
      "as": "Petrol BL"
    },
    {
      "calculate": "datum['Diesel ML'] / 1000",
      "as": "Diesel BL"
    },
    {
      "calculate": "datum.Year == 2011 ? datum['Road fuel ML'] : null",
      "as": "Baseline candidate"
    },
    {
      "joinaggregate": [
        {
          "op": "max",
          "field": "Baseline candidate",
          "as": "Baseline ML"
        },
        {
          "op": "max",
          "field": "Road fuel ML",
          "as": "Peak ML"
        }
      ],
      "groupby": [
        "State"
      ]
    },
    {
      "calculate": "(datum['Road fuel ML'] / datum['Baseline ML'] - 1) * 100",
      "as": "Change from 2011"
    }
  ],
  "width": "container",
  "height": 330,
  "layer": [
    {
      "mark": {
        "type": "rect",
        "stroke": "#ffffff",
        "strokeWidth": 1
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal",
          "title": "Year",
          "axis": {
            "labelAngle": -35,
            "labelColor": "#374151",
            "titleColor": "#374151"
          }
        },
        "y": {
          "field": "State",
          "type": "ordinal",
          "title": "State / territory",
          "sort": {
            "field": "State Order",
            "order": "ascending"
          },
          "axis": {
            "labelFontWeight": "bold",
            "labelColor": "#374151",
            "titleColor": "#374151"
          }
        },
        "color": {
          "field": "Change from 2011",
          "type": "quantitative",
          "title": "Colour: % change from 2011",
          "scale": {
            "domain": [
              -15,
              0,
              15,
              35
            ],
            "range": [
              "#e8b16a",
              "#f4f6f8",
              "#86b3d4",
              "#244a73"
            ]
          },
          "legend": {
            "orient": "right",
            "gradientLength": 220,
            "format": "+.0f"
          }
        },
        "tooltip": [
          {
            "field": "State",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "Year",
            "type": "ordinal",
            "title": "Year"
          },
          {
            "field": "Road fuel BL",
            "type": "quantitative",
            "title": "Total road fuel (BL)",
            "format": ".1f"
          },
          {
            "field": "Petrol BL",
            "type": "quantitative",
            "title": "Petrol (BL)",
            "format": ".1f"
          },
          {
            "field": "Diesel BL",
            "type": "quantitative",
            "title": "Diesel (BL)",
            "format": ".1f"
          },
          {
            "field": "Change from 2011",
            "type": "quantitative",
            "title": "Change from 2011",
            "format": "+.1f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.Year == 2020"
        }
      ],
      "mark": {
        "type": "rect",
        "fillOpacity": 0,
        "stroke": "#d5972f",
        "strokeWidth": 1.5,
        "strokeDash": [
          4,
          3
        ]
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal"
        },
        "y": {
          "field": "State",
          "type": "ordinal",
          "sort": {
            "field": "State Order",
            "order": "ascending"
          }
        },
        "tooltip": [
          {
            "field": "State",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "Year",
            "type": "ordinal",
            "title": "Year"
          },
          {
            "field": "Road fuel BL",
            "type": "quantitative",
            "title": "Total road fuel (BL)",
            "format": ".1f"
          },
          {
            "field": "Petrol BL",
            "type": "quantitative",
            "title": "Petrol (BL)",
            "format": ".1f"
          },
          {
            "field": "Diesel BL",
            "type": "quantitative",
            "title": "Diesel (BL)",
            "format": ".1f"
          },
          {
            "field": "Change from 2011",
            "type": "quantitative",
            "title": "Change from 2011",
            "format": "+.1f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum['Road fuel ML'] == datum['Peak ML']"
        }
      ],
      "mark": {
        "type": "rect",
        "fillOpacity": 0,
        "stroke": "#111827",
        "strokeWidth": 2.4
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal"
        },
        "y": {
          "field": "State",
          "type": "ordinal",
          "sort": {
            "field": "State Order",
            "order": "ascending"
          }
        },
        "tooltip": [
          {
            "field": "State",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "Year",
            "type": "ordinal",
            "title": "Year"
          },
          {
            "field": "Road fuel BL",
            "type": "quantitative",
            "title": "Total road fuel (BL)",
            "format": ".1f"
          },
          {
            "field": "Petrol BL",
            "type": "quantitative",
            "title": "Petrol (BL)",
            "format": ".1f"
          },
          {
            "field": "Diesel BL",
            "type": "quantitative",
            "title": "Diesel (BL)",
            "format": ".1f"
          },
          {
            "field": "Change from 2011",
            "type": "quantitative",
            "title": "Change from 2011",
            "format": "+.1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "fontSize": 10,
        "fontWeight": "bold"
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal"
        },
        "y": {
          "field": "State",
          "type": "ordinal",
          "sort": {
            "field": "State Order",
            "order": "ascending"
          }
        },
        "text": {
          "field": "Road fuel BL",
          "type": "quantitative",
          "format": ".1f"
        },
        "color": {
          "condition": {
            "test": "datum['Change from 2011'] >= 20",
            "value": "#ffffff"
          },
          "value": "#1f2937"
        },
        "tooltip": [
          {
            "field": "State",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "Year",
            "type": "ordinal",
            "title": "Year"
          },
          {
            "field": "Road fuel BL",
            "type": "quantitative",
            "title": "Total road fuel (BL)",
            "format": ".1f"
          },
          {
            "field": "Petrol BL",
            "type": "quantitative",
            "title": "Petrol (BL)",
            "format": ".1f"
          },
          {
            "field": "Diesel BL",
            "type": "quantitative",
            "title": "Diesel (BL)",
            "format": ".1f"
          },
          {
            "field": "Change from 2011",
            "type": "quantitative",
            "title": "Change from 2011",
            "format": "+.1f"
          }
        ]
      }
    }
  ],
  "config": {
    "background": "#ffffff",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#374151",
      "titleColor": "#374151",
      "grid": false,
      "domain": false,
      "tickColor": "#d1d5db"
    },
    "legend": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#374151",
      "titleColor": "#374151"
    },
    "title": {
      "font": "Inter, Arial, sans-serif"
    }
  }
}